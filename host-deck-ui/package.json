{
  "name": "host-deck-ui",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "sync:version": "node scripts/sync-version.mjs",
    "release": "sh ../scripts/release.sh",
    "build": "vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "electron:dev": "node electron/start-dev.cjs",
    "electron:preview": "pnpm build && cross-env HOST_DECK_ELECTRON_MODE=preview electron .",
    "electron:build:server": "node electron/build-server.cjs",
    "electron:pack:win": "pnpm electron:build:server && electron-builder --win",
    "electron:build:win": "pnpm build && pnpm electron:pack:win",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.97.0",
    "@vueuse/core": "^14.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.15.0",
    "echarts": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.4",
    "xgplayer": "^3.0.24"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vicons/carbon": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "naive-ui": "^2.44.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vfonts": "^0.0.3",
    "vite": "^8.0.4",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.foliagesea.hostdeck",
    "productName": "HostDeck",
    "artifactName": "host-deck-electron-windows-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "electron/loading.html",
      "electron/tabs.html",
      "electron/preload.cjs",
      "electron/tabs-preload.cjs",
      "public/favicon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build/electron-server/bundle/bin/server.exe",
        "to": "server/server.exe"
      },
      {
        "from": "dist",
        "to": "web"
      }
    ],
    "win": {
      "icon": "public/favicon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
